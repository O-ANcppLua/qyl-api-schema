          ],
          "opt_in_attributes": [],
          "exporter_ids": [
            "collector-primary"
          ]
        }
      ],
      "export_edges": [
        {
          "exporter_id": "collector-primary",
          "protocol": "otlp_http",
          "endpoint_env_var": "QYL_OTLP_HTTP_ENDPOINT",
          "signals": [
