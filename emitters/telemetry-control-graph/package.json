{
  "name": "@qyl/telemetry-control-graph",
  "version": "0.1.0",
  "description": "Focused TypeSpec emitter for qyl Telemetry Control Graph contracts, verifier slices, JSON Schema, YAML review artifacts, and conformance plans.",
  "type": "module",
  "main": "dist/index.js",
  "tspMain": "lib/main.tsp",
  "exports": {
    ".": {
      "typespec": "./lib/main.tsp",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "prepare": "tsc -p .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@typespec/compiler": "^1.13.0"
  },
  "dependencies": {
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@typespec/compiler": "1.13.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
