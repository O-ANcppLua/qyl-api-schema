{
  "name": "@o-ancpplua/qyl-api-schema",
  "version": "0.2.0",
  "description": "TypeSpec source of truth for qyl API contracts. Emits OpenAPI, JSON Schema, Qyl.Api.Contracts DTOs, and TypeScript contract types; not an OpenTelemetry package, storage schema, or server implementation.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/O-ANcppLua/qyl-api-schema.git"
  },
  "homepage": "https://github.com/O-ANcppLua/qyl-api-schema#readme",
  "bugs": {
    "url": "https://github.com/O-ANcppLua/qyl-api-schema/issues"
  },
  "keywords": [
    "typespec",
    "qyl",
    "observability",
    "contracts",
    "openapi"
  ],
  "type": "module",
  "exports": {
    ".": "./index.tsp",
    "./otel": "./otel/otel-conventions.tsp",
    "./models/*": "./models/*.tsp",
    "./models/agent/*": "./models/agent/*.tsp",
    "./common/*": "./common/*.tsp",
    "./api/*": "./api/*.tsp",
    "./intelligence/*": "./intelligence/*.tsp",
    "./intelligence/seed/*": "./intelligence/seed/*.tsp",
    "./generated/otel-keys": "./generated/otel-keys.gen.tsp"
  },
  "files": [
    "index.tsp",
    "api/**/*.tsp",
    "common/**/*.tsp",
    "intelligence/**/*.tsp",
    "models/**/*.tsp",
    "otel/**/*.tsp",
    "generated/**/*.tsp",
    "generated/README.md",
    "tspconfig.yaml",
    "README.md",
    "VERSIONING.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build:emitters": "tsc -p emitters/telemetry-control-graph && tsc -p emitters/csharp && tsc -p emitters/ts-types && tsc -p emitters/otelconventions-lint",
    "compile": "npm run build:emitters && tsp compile main.tsp",
    "watch": "tsp compile main.tsp --watch",
    "format": "tsp format **/*.tsp",
    "lint": "npm run build:emitters && tsp compile main.tsp --no-emit --warn-as-error",
    "lint:public": "tsp compile index.tsp --no-emit --warn-as-error"
  },
  "peerDependencies": {
    "@typespec/compiler": "^1.13.0 || >=1.13.0-dev.0"
  },
  "devDependencies": {
    "@ancplua/typespec-emit-csharp": "file:./emitters/csharp",
    "@ancplua/typespec-emit-ts-types": "file:./emitters/ts-types",
    "@ancplua/typespec-otel-semconv": "1.41.0-2",
    "@ancplua/typespec-otelconventions-lint": "file:./emitters/otelconventions-lint",
    "@types/node": "25.9.1",
    "@typespec/compiler": "1.13.0",
    "@typespec/events": "0.83.0",
    "@typespec/http": "1.13.0",
    "@typespec/json-schema": "1.13.0",
    "@typespec/openapi": "1.13.0",
    "@typespec/openapi3": "1.13.0",
    "@typespec/rest": "0.83.0",
    "@typespec/sse": "0.83.0",
    "@typespec/streams": "0.83.0",
    "@typespec/versioning": "0.83.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "@qyl/telemetry-control-graph": "file:./emitters/telemetry-control-graph"
  },
  "dependencies": {
    "@azure-tools/typespec-azure-core": "^0.69.0",
    "@typespec/xml": "^0.83.0"
  }
}
